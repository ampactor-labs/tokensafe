# === REQUIRED ===
TREASURY_WALLET_ADDRESS=     # Your Solana wallet address (receives USDC payments)
HELIUS_API_KEY=              # Free tier from helius.dev (1M credits/month)

# === OPTIONAL (have sensible defaults) ===
FACILITATOR_URL=https://facilitator.payai.network
SOLANA_NETWORK=devnet        # 'mainnet' or 'devnet'
NODE_ENV=development
# PORT=3000 — Railway injects PORT automatically. Only set for local dev if 3000 is taken.
RATE_LIMIT_PER_MINUTE=60     # Per-IP rate limit for paid endpoints
LITE_RATE_LIMIT_PER_MINUTE=30 # Per-IP rate limit for free endpoints (lite, decide, MCP)

# === RESPONSE SIGNING (optional) ===
# RESPONSE_SIGNING_KEY=        # Hex-encoded PKCS8 Ed25519 private key for deterministic response signing.
#                               # If unset, an ephemeral keypair is generated at startup (key changes on restart).
#                               # Generate: node -e "const c=require('crypto');const k=c.generateKeyPairSync('ed25519');console.log(k.privateKey.export({type:'pkcs8',format:'der'}).toString('hex'))"

# === RPC FAILOVER (optional) ===
# HELIUS_API_KEY_BACKUP=       # Secondary Helius key — auto-failover after 3 consecutive primary failures

# === DISCOVERY (optional) ===
# X402_OWNERSHIP_PROOF=         # Ownership proof for /.well-known/x402 discovery document

# === WEBHOOK / ADMIN / METRICS (optional) ===
# WEBHOOK_ADMIN_BEARER=        # Bearer token for webhook CRUD, API key CRUD, and GET /metrics routes
#                               # If unset, admin routes return 401 and /metrics returns 404
# DB_PATH=data/tokensafe.db    # SQLite database path (default: data/tokensafe.db, use :memory: for tests)
# MAX_WEBHOOKS_PER_TOKEN=100   # Max active subscriptions per mint address
# MONITOR_INTERVAL_MS=300000   # Background monitor poll interval (default 5min = 300000ms)

# === SUBSCRIPTION TIERS (optional) ===
# PRO_MONTHLY_LIMIT=6000       # Monthly check limit for Pro API keys (default 6000)
# PRO_RATE_LIMIT=200            # Requests/min for Pro API keys (default 200)
# ENTERPRISE_RATE_LIMIT=600     # Requests/min for Enterprise API keys (default 600)

# === TEST WALLETS (not used by server — test/smoke scripts only) ===
# SVM_PRIVATE_KEY=            # Base58-encoded 64-byte Solana keypair (see DEPLOY.md §4)
# TEST_WALLET_ADDRESS=          # Devnet wallet for x402 test client
# MAINNET_TEST_WALLET_ADDRESS=  # Mainnet wallet for smoke tests (funded with real USDC)
